# Copy to .env and fill in. The server refuses to start in production unless the
# two keys are set.
NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# --- Storage ---------------------------------------------------------------
# Set DATABASE_URL to use Postgres. Leave it blank to fall back to the JSON file
# store (dev only). node-pg-migrate reads DATABASE_URL too.
DATABASE_URL=postgres://daemonheim:password@localhost:5432/daemonheim
DATA_FILE=./data/events.json
PG_POOL_MAX=10
# Set to "true" only for managed Postgres that requires TLS.
PG_SSL=false

# --- Auth (REQUIRED in production) -----------------------------------------
# Generate each with: openssl rand -hex 24
# INGEST_KEY  -> sent by the Alt1 app as the  x-ingest-key  header (write access)
# ADMIN_KEY   -> sent by you as the           x-admin-key   header (read-raw + delete)
INGEST_KEY=
ADMIN_KEY=

# --- CORS / limits ---------------------------------------------------------
# The dashboard's origin, e.g. https://your-user.github.io  (locks reads in prod)
DASHBOARD_ORIGIN=
RATE_MAX=200
