{
  "name": "daemonheim-tracker",
  "version": "0.1.0",
  "private": true,
  "description": "Dungeoneering-only Ironman progress tracker for RS3 — Alt1 screen-reader app, ingest API, and a public companion dashboard.",
  "workspaces": [
    "packages/*",
    "apps/*",
    "services/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:shared": "npm run build -w @daemonheim/shared",
    "dev:api": "npm run dev -w @daemonheim/api",
    "dev:alt1": "npm run dev -w @daemonheim/alt1-app",
    "dev:dashboard": "npm run dev -w @daemonheim/dashboard",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "devDependencies": {
    "vitest": "^2.1.9"
  }
}
